msgid "Register"
msgstr "登録"

msgid "Key"
msgstr "キー"

msgid "Description"
msgstr "説明"

msgid "Value"
msgstr "値"

msgid "Update"
msgstr "更新"

msgid "There are currently no custom variables registered. Please register a new one."
msgstr "現在、カスタム変数は登録されていません。新しい変数を登録してください。"

msgid "<a href="?task=1">Update</a>"
msgstr "<a href="?task=1">更新</a>"

msgid "<a href="?task=0">Register</a>"
msgstr "<a href="?task=0">登録</a>"

msgid "<a href="?task=0">Key[@key] has already been registered."
msgstr "<a href="?task=0">キー[@key]は既に登録済みです。"

msgid "Key[@key] registered.(Value is [@value])"
msgstr "キー[@key]を登録しました。(値：@value)"

msgid "Key[@key] updated.(Value is [@value])"
msgstr "キー[@key]を更新しました。(値：@value)"

msgid "<p><b>Usage:</b><br>Please write {{ custom_variable('@key') }} in any Twig. (@key is the name of the key. And please enclose @key in single quotes.)</p>"
msgstr "<p><b>使い方</b><br>任意のTwigで{{ custom_variable(@key) }}を記述してください。(@keyはキーの名称です。また、@keyをシングルクォートで囲ってください。)</p>"
